{
    "exclude": ["node_modules/**"],
    "lib": ["ESNext"],
    "compilerOptions": {
        "strict": true,
        "noImplicitAny": false,
        "noEmitOnError": true,
        "noEmit": true,
        "module": "commonjs",
        "esModuleInterop": true,
        "target": "esnext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "sourceMap": true,
        "outDir": "dist",
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "allowUnreachableCode": false,
        "alwaysStrict": true,
        "noFallthroughCasesInSwitch": true,
        "strictNullChecks": true,
        "noImplicitReturns": true,
        "skipLibCheck": true,
        "allowJs": true,
        "baseUrl": "./",
        "paths": {
            "@native/*": ["roze/native/*"],
            "@roze/*": ["roze/src/*", "roze/*"],
            "@origin/*": ["origin/src/*"],
            "@lutz/*": ["lutz/src/*"],
            "@sosu/*": ["sosu/src/*"],
            "@illusive/*": ["Illusive/src/*"],
            "@illusicord/*": ["illusicord/src/*"],
            "@common/*": ["common/*"],
            "@admin/*": ["admin/*"],
            "@sample/*": ["sample/*"],
        }
    },
    "ts-node": {
        "require": ["tsconfig-paths/register"]
    }
}