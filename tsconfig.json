{
    "exclude": ["node_modules/**"],
    "lib": ["ESNext"],
    "compilerOptions": {
        "strict": true,
        "noImplicitAny": false,
        "noEmitOnError": true,
        "noEmit": true,
        "esModuleInterop": true,
        "target": "es2022",
        "moduleResolution": "nodenext",
        "module": "nodenext",
        "resolveJsonModule": true,
        "sourceMap": true,
        "outDir": "dist",
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "allowUnreachableCode": false,
        "alwaysStrict": true,
        "noFallthroughCasesInSwitch": true,
        "strictNullChecks": true,
        "noImplicitReturns": true,
        "skipLibCheck": true,
        "allowJs": true,
        "paths": {
            "@native/*": ["./roze/native/*"],
            "@lib/*": ["./roze/lib/*"],
            "@roze/*": ["./roze/src/*", "./roze/*"],
            "@arneb/*": ["./arneb/*"],
            "@origin/*": ["./origin/src/*"],
            "@lutz/*": ["./lutz/src/*"],
            "@sosu/*": ["./sosu/src/*"],
            "@illusive/*": ["./Illusive/src/*"],
            "@illusicord/*": ["./illusicord/src/*"],
            "@common/*": ["./common/*"],
            "@admin/*": ["./admin/*"],
            "@sample/*": ["./sample/*"],
        }
    },
    "ts-node": {
        "require": ["tsconfig-paths/register"]
    }
}