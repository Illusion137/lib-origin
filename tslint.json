{
    "extends": "tslint:recommended",
    "rules": {
        "callable-types": true,
        "class-name": false,
        "comment-format": [
            true,
            "check-space"
        ],
        "curly": false,
        "eofline": false,
        "forin": true,
        "import-blacklist": [
            true
        ],
        "import-spacing": true,
        "indent": [
            true,
            "spaces"
        ],
        "interface-over-type-literal": true,
        "interface-name": false,
        "label-position": true,
        "max-line-length": [
            true,
            140
        ],
        "member-access": false,
        "member-ordering": [
            true,
            {
                "order": "fields-first"
            }
        ],
        "no-arg": true,
        "no-namespace": false,
        "no-bitwise": true,
        "no-console": [
            true,
            "debug",
            "info",
            "time",
            "timeEnd",
            "trace"
        ],
        "no-construct": true,
        "no-debugger": true,
        "no-duplicate-variable": true,
        "no-empty": false,
        "no-empty-interface": true,
        "no-inferrable-types": [
            true,
            "ignore-params"
        ],
        "no-shadowed-variable": true,
        "no-string-literal": false,
        "no-string-throw": true,
        "no-switch-case-fall-through": true,
        "no-trailing-whitespace": false,
        "no-unused-expression": true,
        "no-var-keyword": true,
        "object-literal-sort-keys": false,
        "prefer-const": true,
        "prefer-readonly": true,
        "quotemark": false,
        "radix": false,
        "semicolon": false,
        "trailing-comma": false,
        "space-before-function-paren": false,
        "arrow-parens": false,
        "switch-final-break": true,
        "array-type": [
            true,
            "array"
        ],
        "triple-equals": [
            true,
            "allow-null-check"
        ],
        "typedef-whitespace": [
            true,
            {
                "call-signature": "nospace",
                "index-signature": "nospace",
                "parameter": "nospace",
                "property-declaration": "nospace",
                "variable-declaration": "nospace"
            }
        ],
        "unified-signatures": true,
        "variable-name": false,
        "whitespace": false,
        "type-literal-delimiter": false
    },
    "jsRules": {
        "max-line-length": {
            "options": [
                120
            ]
        }
    }
}